# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (publishable) key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key (bypasses RLS — server-only, never expose client-side)
SUPABASE_SERVICE_ROLE_KEY=

# Gemini API key — required for File Search indexing and chat
GEMINI_API_KEY=

# Resend API key — transactional email
RESEND_API_KEY=

# Public URL used in email CTAs (e.g. https://www.regwatchmnl.net)
APP_URL=

# Optional — From address for briefing emails, defaults to RegWatch <briefings@mnladvocates.com>
RESEND_FROM=

# Optional — shared secret for the briefing-sent webhook, sent as x-webhook-secret
WEBHOOK_SECRET=

# Unused — retained from pre-Phase-A architecture, not called in current code. Do not delete.
ANTHROPIC_API_KEY=
